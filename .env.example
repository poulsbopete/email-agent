# Required: Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=your-api-key-here

# iMessage notifications when the agent needs your input (macOS only)
# Phone: E.164 with country code (+12064517107), or Apple ID email of an existing Messages contact
# US numbers need +1 — bare 10-digit (2064517107) usually fails AppleScript participant lookup
IMESSAGE_NOTIFY_TO=+15551234567

# Send replies automatically (true) or create Gmail drafts for review (false, default)
# AUTO_SEND_RESPONSES=false

# Claude model for email classification and reply drafting
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Max unread emails processed per hourly run (default: 10)
# MAX_EMAILS_PER_RUN=10

# Optional: paths to Gmail OAuth files (defaults shown below)
# GMAIL_CREDENTIALS_FILE=credentials.json
# GMAIL_CREDENTIALS_FILE=client_secret.json
# GMAIL_TOKEN_FILE=token.json

# CI / cloud hosting: paste full JSON contents (see CLOUD_HOSTING.md)
# GMAIL_CREDENTIALS_JSON={"installed":{...}}
# GMAIL_TOKEN_JSON={"token":"...","refresh_token":"...",...}

# Legacy daemon mode only — hourly runs use launchd, not this interval
# CHECK_INTERVAL=3600
